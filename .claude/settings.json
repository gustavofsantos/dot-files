{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1"
  },
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Task",
      "Bash(basename *)",
      "Bash(diff *)",
      "Bash(dirname *)",
      "Bash(file *)",
      "Bash(ls *)",
      "Bash(md5 *)",
      "Bash(readlink *)",
      "Bash(realpath *)",
      "Bash(shasum *)",
      "Bash(stat *)",
      "Bash(tree *)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(docker *)",
      "Bash(date *)",
      "Bash(df *)",
      "Bash(du *)",
      "Bash(hostname *)",
      "Bash(id *)",
      "Bash(ps *)",
      "Bash(pwd *)",
      "Bash(uname *)",
      "Bash(whoami *)",
      "Bash(cut *)",
      "Bash(jq *)",
      "Bash(sort *)",
      "Bash(tr *)",
      "Bash(uniq *)",
      "Bash(wc *)",
      "Bash(yq *)",
      "Bash(tmux *)",
      "Bash(claude-run *)",
      "Bash(claude-sessions *)",
      "Bash(brew info *)",
      "Bash(brew list *)",
      "Bash(npm *)",
      "Bash(pip list *)",
      "Bash(pip show *)",
      "Bash(node *)",
      "Bash(python --version *)",
      "Bash(ruby --version *)",
      "Bash(curl *)",
      "Bash(echo *)",
      "Bash(mkdir *)",
      "Bash(wget *)",
      "Bash(which *)",
      "Bash(rg *)",
      "Bash(fd *)",
      "Bash(find *)",
      "Bash(awk *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(sed *)",
      "ExitPlanMode(*)",
      "WebFetch(domain:*)",
      "WebSearch"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./config/credentials.json)",
      "Read(./build/**)",
      "Read(~/.aws/**)",
      "Read(~/.ssh/**)",
      "Bash(dd *)",
      "Bash(diskutil *)",
      "Bash(mkfs *)",
      "Bash(rm -rf / *)",
      "Bash(rm -rf /* *)",
      "Bash(rm -rf ~ *)",
      "Bash(rm -rf $HOME *)",
      "Bash(sudo rm -rf / *)",
      "Bash(sudo rm -rf /* *)"
    ],
    "ask": [
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(gh pr merge *)",
      "Bash(docker push *)",
      "Bash(npm publish *)"
    ],
    "defaultMode": "auto",
    "additionalDirectories": ["~/engineering"]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "hooks-runner claude SessionStart"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "hooks-runner claude UserPromptSubmit"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "hooks-runner claude Stop"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "hooks-runner claude SessionEnd"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "hooks-runner claude Notification"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "hooks-runner claude SubagentStart"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "hooks-runner claude SubagentStop"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "claude-statusline"
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Calculando os arreios",
      "Cozinhando o mate",
      "Ajeitando a carga na carroça",
      "Peleando com as linhas de código",
      "Desatando esse nó cego",
      "Campereando o código pra achar o rastro",
      "Remexendo o braseiro pra clarear as ideias",
      "Passando o esmeril nessa função",
      "Caçando pulga em pelo de cusco",
      "Verificando se essa gambiarra não vai dar xarope",
      "Testando se o laço tá firme ou se vai arrebentar",
      "Mateando",
      "Matutando",
      "Ruminando",
      "Gauderiando",
      "Chasqueando",
      "Carpindo",
      "Ajeitando",
      "Peleando",
      "Cuscando",
      "Firmando"
    ]
  },
  "theme": "custom:nord",
  "teammateMode": "tmux",
  "defaultMode": "auto"
}
