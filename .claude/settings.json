{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Task",
      "Bash(basename *)",
      "Bash(diff *)",
      "Bash(dirname *)",
      "Bash(file *)",
      "Bash(ls *)",
      "Bash(md5 *)",
      "Bash(readlink *)",
      "Bash(realpath *)",
      "Bash(shasum *)",
      "Bash(stat *)",
      "Bash(tree *)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(docker *)",
      "Bash(date *)",
      "Bash(df *)",
      "Bash(du *)",
      "Bash(hostname *)",
      "Bash(id *)",
      "Bash(ps *)",
      "Bash(pwd *)",
      "Bash(uname *)",
      "Bash(whoami *)",
      "Bash(cut *)",
      "Bash(jq *)",
      "Bash(sort *)",
      "Bash(tr *)",
      "Bash(uniq *)",
      "Bash(wc *)",
      "Bash(yq *)",
      "Bash(tmux *)",
      "Bash(claude-run *)",
      "Bash(claude-sessions *)",
      "Bash(brew info *)",
      "Bash(brew list *)",
      "Bash(npm *)",
      "Bash(pip list *)",
      "Bash(pip show *)",
      "Bash(node *)",
      "Bash(python --version *)",
      "Bash(ruby --version *)",
      "Bash(curl *)",
      "Bash(echo *)",
      "Bash(mkdir *)",
      "Bash(wget *)",
      "Bash(which *)",
      "ExitPlanMode(*)",
      "WebFetch(domain:*)",
      "WebSearch"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./config/credentials.json)",
      "Read(./build/**)",
      "Read(~/.aws/**)",
      "Read(~/.ssh/**)",
      "Bash(dd *)",
      "Bash(diskutil *)",
      "Bash(mkfs *)",
      "Bash(rm -rf / *)",
      "Bash(rm -rf /* *)",
      "Bash(rm -rf ~ *)",
      "Bash(rm -rf $HOME *)",
      "Bash(sudo rm -rf / *)",
      "Bash(sudo rm -rf /* *)"
    ],
    "ask": [
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(gh pr merge *)",
      "Bash(docker push *)",
      "Bash(npm publish *)"
    ],
    "defaultMode": "auto",
    "additionalDirectories": ["~/engineering"]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Read|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "kb-fact-track"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "claude-hook-vault-lint"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "claude-hook-notify"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "claude-hook-notify"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "claude-hook-session-track"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "claude-statusline"
  },
  "theme": "custom:nord",
  "teammateMode": "tmux",
  "defaultMode": "auto"
}
