{
  "description": "system-cartographer: protect the schema (PreToolUse deny-by-default + acceptance-token handshake) and validate the map after instance writes (PostToolUse).",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/pretooluse_guard.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/posttooluse_validate.py\"",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
