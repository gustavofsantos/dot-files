#!/usr/bin/env bash
# cursor-hook-session-track — register/refresh a Cursor Agent session and its pane.
#
# Invoked via hooks-runner for the cursor harness:
#   "sessionStart":       hooks-runner cursor sessionStart
#   "beforeSubmitPrompt": hooks-runner cursor beforeSubmitPrompt
#
# Receives the CanonicalEvent envelope on stdin (built by hooks-runner):
#   { harness, event, session_id, cwd, raw: { ...original Cursor payload... } }
#
# We translate Cursor's fields into the SAME state-file schema that Claude
# writes, so `claude-sessions` lists Cursor and Claude agents side by side in
# one picker.  `beforeSubmitPrompt` is the workhorse: it creates the state file
# if `sessionStart` didn't already, so the session registers on its first
# prompt regardless.
#
# State: ~/.agent-sessions/<session_id>.json
#   { session_id, agent, track_name, task, dir, pane, status, started_at,
#     last_activity, notifications }

set -euo pipefail

INPUT=$(cat 2>/dev/null || true)
SESSIONS_DIR="${AGENT_SESSIONS_DIR:-${HOME}/.agent-sessions}"
command -v jq &>/dev/null || exit 0

jget() { printf '%s' "$INPUT" | jq -r "$1 // empty" 2>/dev/null; }

# Read session_id from the envelope (set by hooks-runner adapter).  Fall back
# to the raw Cursor conversation_id for direct invocations without the runner.
SESSION_ID="$(jget '.session_id')"
[[ -z "$SESSION_ID" ]] && SESSION_ID="$(jget '.raw.conversation_id')"
[[ -z "$SESSION_ID" ]] && SESSION_ID="$(jget '.conversation_id')"
[[ -z "$SESSION_ID" ]] && exit 0

# cwd from envelope; fall back to raw Cursor workspace_roots and env vars.
DIR="$(jget '.cwd')"
[[ -z "$DIR" ]] && DIR="$(jget '.raw.workspace_roots[0]')"
[[ -z "$DIR" ]] && DIR="$(jget '.workspace_roots[0]')"
DIR="${DIR:-${CURSOR_PROJECT_DIR:-${CLAUDE_PROJECT_DIR:-$PWD}}}"
PANE="${TMUX_PANE:-}"
TRACK_NAME="$(basename "$DIR")"
NOW=$(date +%s)

mkdir -p "$SESSIONS_DIR"
STATE="${SESSIONS_DIR}/${SESSION_ID}.json"

if [[ -f "$STATE" ]]; then
  TMP=$(mktemp)
  jq --argjson ts "$NOW" --arg pane "$PANE" --arg dir "$DIR" \
    '.status = "running"
     | .last_activity = $ts
     | (if $pane != "" then .pane = $pane else . end)
     | (if ((.dir // "") == "") and $dir != "" then .dir = $dir else . end)' \
    "$STATE" > "$TMP" && mv "$TMP" "$STATE"
else
  jq -n \
    --arg sid "$SESSION_ID" --arg name "$TRACK_NAME" \
    --arg dir "$DIR" --arg pane "$PANE" --argjson ts "$NOW" \
    '{session_id:$sid, agent:"cursor", track_name:$name, task:"", dir:$dir,
      pane:$pane, status:"running", started_at:$ts, last_activity:$ts,
      notifications:0}' \
    > "$STATE"
fi

exit 0
