#!/usr/bin/env bash
set -euo pipefail

[[ $# -lt 1 ]] && { echo "Usage: kb-search <term> [term2 ...]" >&2; exit 1; }

ENGINEERING_DIR="${ENGINEERING_DIR:-$HOME/engineering}"
KB_PEEK="${KB_PEEK:-$(dirname "$(realpath "$0")")/kb-peek}"

# Multiple args become an rg alternation: kb-search auth token → auth|token
pattern=$(printf '%s|' "$@")
pattern="${pattern%|}"

hits=0
for artifact in issues facts spikes; do
  dir="$ENGINEERING_DIR/$artifact"
  [[ -d "$dir" ]] || continue
  while IFS= read -r f; do
    echo "── $f"
    "$KB_PEEK" "$f"
    echo ""
    hits=$((hits + 1))
  done < <(rg -l --ignore-case "$pattern" "$dir" 2>/dev/null)
done

# Glossary lives in one file; print each matching `## ` term block, not the whole file.
glossary="$ENGINEERING_DIR/terms/GLOSSARY.md"
if [[ -f "$glossary" ]]; then
  match=$(awk -v pat="$pattern" '
    BEGIN { IGNORECASE = 1 }
    /^## / {
      if (block != "" && hit) printf "%s", block
      block = $0 "\n"; hit = ($0 ~ pat) ? 1 : 0
      next
    }
    { block = block $0 "\n"; if ($0 ~ pat) hit = 1 }
    END { if (block != "" && hit) printf "%s", block }
  ' "$glossary")
  if [[ -n "$match" ]]; then
    echo "── $glossary"
    echo "$match"
    hits=$((hits + 1))
  fi
fi

if [[ $hits -eq 0 ]]; then
  echo "(no matches for: $*)"
fi
