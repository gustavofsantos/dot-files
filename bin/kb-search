#!/usr/bin/env bash
set -euo pipefail

[[ $# -lt 1 ]] && { echo "Usage: kb-search <term> [term2 ...]" >&2; exit 1; }

ENGINEERING_DIR="${ENGINEERING_DIR:-$HOME/engineering}"
KB_PEEK="${KB_PEEK:-$(dirname "$(realpath "$0")")/kb-peek}"

# Multiple args become an rg alternation: kb-search auth token → auth|token
pattern=$(printf '%s|' "$@")
pattern="${pattern%|}"

hits=0

# Root notes (exclude generated files)
while IFS= read -r f; do
  base=$(basename "$f")
  [[ "$base" == "INDEX.md" || "$base" == "DOMAIN_MAP.md" ]] && continue
  echo "── $f"
  "$KB_PEEK" "$f"
  echo ""
  hits=$((hits + 1))
done < <(rg -l --ignore-case "$pattern" "$ENGINEERING_DIR"/*.md 2>/dev/null || true)

# Subdirectory artifacts
for artifact in issues spikes; do
  dir="$ENGINEERING_DIR/$artifact"
  [[ -d "$dir" ]] || continue
  while IFS= read -r f; do
    echo "── $f"
    "$KB_PEEK" "$f"
    echo ""
    hits=$((hits + 1))
  done < <(rg -l --ignore-case "$pattern" "$dir" 2>/dev/null)
done

if [[ $hits -eq 0 ]]; then
  echo "(no matches for: $*)"
fi
