#!/usr/bin/env bash
# claude-hook-session-end — SessionEnd hook: mark a session as ended.
#
# Wire in .claude/settings.json:
#   "SessionEnd": [{"type":"command","command":"claude-hook-session-end"}]
#
# Keeps the state file (recent history) but flips status so `claude-sessions`
# shows it as ended rather than a live, jump-to-able pane.

set -euo pipefail

INPUT=$(cat 2>/dev/null || true)
SESSIONS_DIR="${AGENT_SESSIONS_DIR:-${HOME}/.agent-sessions}"
command -v jq &>/dev/null || exit 0

SESSION_ID="${CLAUDE_SESSION_ID:-$(printf '%s' "$INPUT" | jq -r '.session_id // empty' 2>/dev/null)}"
[[ -z "$SESSION_ID" ]] && exit 0

STATE="${SESSIONS_DIR}/${SESSION_ID}.json"
[[ -f "$STATE" ]] || exit 0

NOW=$(date +%s)
TMP=$(mktemp)
jq --argjson ts "$NOW" '.status = "ended" | .last_activity = $ts | .pane = ""' \
  "$STATE" > "$TMP" && mv "$TMP" "$STATE"

exit 0
