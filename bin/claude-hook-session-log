#!/usr/bin/env python3
"""
claude-hook-session-log — append structured events to ~/.agent-sessions/<id>.jsonl

Handles three events dispatched by hooks-runner:
  turn_end      (Claude Stop or Cursor stop) → parse transcript → append events
  SubagentStart (fires in parent)            → create subagent dir + session_start
  SubagentStop  (fires in parent)            → parse agent_transcript_path → append

Event log: ~/.agent-sessions/<session_id>.jsonl — append-only, one JSON per line.
A special {"type":"_cursor","uuid":"..."} line is appended after each turn to
enable idempotent incremental parsing on subsequent calls.

Cursor fallback (transcript_path is null): emits file_change events from
`git diff HEAD --name-only` and a turn_end with no tokens or model.
"""

import json
import os
import subprocess
import sys
import time
from pathlib import Path

SESSIONS_DIR = Path(os.environ.get("AGENT_SESSIONS_DIR") or "").expanduser() \
    if os.environ.get("AGENT_SESSIONS_DIR") \
    else Path.home() / ".agent-sessions"
HOOK_EVENT = os.environ.get("HOOK_EVENT", "")
HOOK_HARNESS = os.environ.get("HOOK_HARNESS", "")


# ── helpers ────────────────────────────────────────────────────────────────────

def jget(obj, *keys, default=None):
    for k in keys:
        if isinstance(obj, dict):
            obj = obj.get(k)
        elif isinstance(obj, (list, tuple)) and isinstance(k, int):
            try:
                obj = obj[k]
            except IndexError:
                return default
        else:
            return default
        if obj is None:
            return default
    return obj


def read_cursor_uuid(log_path: Path) -> str | None:
    """Return the uuid of the last processed transcript entry, or None."""
    if not log_path.exists():
        return None
    last = None
    for line in log_path.read_text().splitlines():
        line = line.strip()
        if not line:
            continue
        try:
            obj = json.loads(line)
            if obj.get("type") == "_cursor":
                last = obj.get("uuid")
        except json.JSONDecodeError:
            continue
    return last


def last_turn_number(log_path: Path) -> int:
    """Return the highest turn number already written to the log."""
    if not log_path.exists():
        return 0
    last = 0
    for line in log_path.read_text().splitlines():
        try:
            obj = json.loads(line)
            if obj.get("type") == "turn_end":
                last = max(last, int(obj.get("turn", 0)))
        except (json.JSONDecodeError, ValueError, TypeError):
            continue
    return last


def parse_transcript(path: str) -> list[dict]:
    entries = []
    try:
        for line in Path(path).read_text().splitlines():
            line = line.strip()
            if not line:
                continue
            try:
                entries.append(json.loads(line))
            except json.JSONDecodeError:
                continue
    except OSError:
        pass
    return entries


def entries_since(entries: list[dict], cursor_uuid: str | None) -> list[dict]:
    """Return entries after cursor_uuid in the list, or all if cursor is None."""
    if cursor_uuid is None:
        return entries
    idx = None
    for i, e in enumerate(entries):
        if e.get("uuid") == cursor_uuid:
            idx = i
            break
    if idx is None:
        return entries
    return entries[idx + 1:]


def extract_model(entries: list[dict]) -> str | None:
    for e in entries:
        if e.get("type") == "assistant":
            return jget(e, "message", "model")
    return None


def file_op(tool_name: str) -> str:
    if tool_name == "Write":
        return "write"
    return "edit"


def user_text(message: dict) -> str:
    content = message.get("content", "")
    if isinstance(content, str):
        return content
    if isinstance(content, list):
        parts = [c.get("text", "") for c in content if c.get("type") == "text"]
        return "\n".join(parts)
    return ""


# ── core: process a transcript into log events ─────────────────────────────────

def process_transcript(
    log_path: Path,
    transcript_path: str,
    session_id: str,
    ts: int,
    harness: str = "claude",
) -> None:
    entries = parse_transcript(transcript_path)
    if not entries:
        return

    cursor = read_cursor_uuid(log_path)
    new_entries = entries_since(entries, cursor)
    if not new_entries:
        return

    is_new = not log_path.exists()
    events: list[dict] = []

    if is_new:
        model = extract_model(entries)
        ev: dict = {
            "type": "session_start",
            "ts": ts,
            "session_id": session_id,
            "harness": harness,
        }
        if model:
            ev["model"] = model
        events.append(ev)

    turn_num = last_turn_number(log_path)
    last_uuid: str | None = None
    last_usage: dict | None = None
    last_model: str | None = None

    for entry in new_entries:
        etype = entry.get("type")
        uuid = entry.get("uuid")
        if uuid:
            last_uuid = uuid

        if etype == "user" and not entry.get("isMeta") and not entry.get("isSidechain"):
            msg = entry.get("message", {})
            text = user_text(msg)
            if text:
                turn_num += 1
                events.append({
                    "type": "message",
                    "ts": ts,
                    "turn": turn_num,
                    "role": "user",
                    "text": text[:4000],
                })

        elif etype == "assistant" and not entry.get("isSidechain"):
            msg = entry.get("message", {})
            usage = msg.get("usage")
            if usage:
                last_usage = usage
            model = msg.get("model")
            if model:
                last_model = model
            for block in msg.get("content", []):
                btype = block.get("type")
                if btype == "text":
                    text = block.get("text", "").strip()
                    if text:
                        events.append({
                            "type": "message",
                            "ts": ts,
                            "turn": turn_num,
                            "role": "assistant",
                            "text": text[:4000],
                        })
                elif btype == "tool_use" and block.get("name") in ("Write", "Edit", "NotebookEdit"):
                    inp = block.get("input", {})
                    path = inp.get("file_path") or inp.get("path", "")
                    if path:
                        events.append({
                            "type": "file_change",
                            "ts": ts,
                            "turn": turn_num,
                            "op": file_op(block["name"]),
                            "path": path,
                        })

    te: dict = {"type": "turn_end", "ts": ts, "turn": turn_num}
    if last_model:
        te["model"] = last_model
    if last_usage:
        te["tokens"] = {
            "input": last_usage.get("input_tokens", 0),
            "output": last_usage.get("output_tokens", 0),
            "cache_read": last_usage.get("cache_read_input_tokens", 0),
            "cache_write": last_usage.get("cache_creation_input_tokens", 0),
        }
    events.append(te)

    if last_uuid:
        events.append({"type": "_cursor", "uuid": last_uuid})

    _append(log_path, events)


def process_cursor_turn(
    log_path: Path,
    session_id: str,
    cwd: str,
    ts: int,
) -> None:
    """Cursor fallback: no transcript — derive file changes from git diff."""
    is_new = not log_path.exists()
    events: list[dict] = []

    if is_new:
        events.append({
            "type": "session_start",
            "ts": ts,
            "session_id": session_id,
            "harness": "cursor",
        })

    turn_num = last_turn_number(log_path) + 1

    try:
        out = subprocess.check_output(
            ["git", "diff", "HEAD", "--name-only"],
            cwd=cwd, text=True, stderr=subprocess.DEVNULL,
        )
        for changed in out.strip().splitlines():
            changed = changed.strip()
            if changed:
                events.append({
                    "type": "file_change",
                    "ts": ts,
                    "turn": turn_num,
                    "op": "edit",
                    "path": changed,
                })
    except (subprocess.CalledProcessError, FileNotFoundError, OSError):
        pass

    events.append({"type": "turn_end", "ts": ts, "turn": turn_num})
    _append(log_path, events)


def _append(log_path: Path, events: list[dict]) -> None:
    log_path.parent.mkdir(parents=True, exist_ok=True)
    with log_path.open("a") as f:
        for ev in events:
            f.write(json.dumps(ev, separators=(",", ":")) + "\n")


# ── event handlers ─────────────────────────────────────────────────────────────

def handle_turn_end(envelope: dict) -> None:
    session_id = envelope.get("session_id") or os.environ.get("CLAUDE_SESSION_ID", "")
    if not session_id:
        return
    ts = int(time.time())
    log_path = SESSIONS_DIR / f"{session_id}.jsonl"
    transcript_path = envelope.get("transcript_path") or jget(envelope, "raw", "transcript_path")
    harness = envelope.get("harness") or HOOK_HARNESS or "claude"

    if transcript_path:
        process_transcript(log_path, transcript_path, session_id, ts, harness)
    elif harness == "cursor":
        cwd = envelope.get("cwd") or jget(envelope, "raw", "workspace_roots", 0) or ""
        if cwd:
            process_cursor_turn(log_path, session_id, cwd, ts)


def handle_subagent_start(envelope: dict) -> None:
    session_id = envelope.get("session_id") or os.environ.get("CLAUDE_SESSION_ID", "")
    if not session_id:
        return
    raw = envelope.get("raw", {})
    agent_id = raw.get("agent_id", "")
    agent_type = raw.get("agent_type", "")
    if not agent_id:
        return

    subdir = SESSIONS_DIR / session_id
    subdir.mkdir(parents=True, exist_ok=True)
    log_path = subdir / f"{agent_id}.jsonl"

    if not log_path.exists():
        ts = int(time.time())
        ev: dict = {
            "type": "session_start",
            "ts": ts,
            "session_id": agent_id,
            "harness": "claude",
        }
        if agent_type:
            ev["agent_type"] = agent_type
        with log_path.open("w") as f:
            f.write(json.dumps(ev, separators=(",", ":")) + "\n")


def handle_subagent_stop(envelope: dict) -> None:
    session_id = envelope.get("session_id") or os.environ.get("CLAUDE_SESSION_ID", "")
    if not session_id:
        return
    raw = envelope.get("raw", {})
    agent_id = raw.get("agent_id", "")
    agent_transcript_path = raw.get("agent_transcript_path", "")
    if not agent_id or not agent_transcript_path:
        return

    subdir = SESSIONS_DIR / session_id
    subdir.mkdir(parents=True, exist_ok=True)
    log_path = subdir / f"{agent_id}.jsonl"

    ts = int(time.time())
    process_transcript(log_path, agent_transcript_path, agent_id, ts, harness="claude")


# ── main ───────────────────────────────────────────────────────────────────────

def main() -> None:
    try:
        envelope = json.loads(sys.stdin.read())
    except json.JSONDecodeError:
        envelope = {}

    event = HOOK_EVENT or envelope.get("event") or envelope.get("raw_event", "")

    if event == "turn_end":
        handle_turn_end(envelope)
    elif event == "SubagentStart":
        handle_subagent_start(envelope)
    elif event == "SubagentStop":
        handle_subagent_stop(envelope)


if __name__ == "__main__":
    main()
