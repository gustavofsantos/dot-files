#!/usr/bin/env bash
# Counts reads of ~/engineering/ root notes. Called as a PostToolUse hook.
# Captures three paths:
#   Read tool   → direct root note read
#   kb-peek     → command string contains a root note path
#   kb-search   → parses tool_response output for "── .../engineering/<file>.md" lines
set -euo pipefail

ENGINEERING_DIR="${ENGINEERING_DIR:-$HOME/engineering}"
METADATA_DIR="$ENGINEERING_DIR/.metadata"
READS_FILE="$METADATA_DIR/note-reads.json"

event=$(cat)
tool_name=$(echo "$event" | jq -r '.tool_name // empty')

notes=()

# Root note pattern: directly under engineering/, not in a subdir
is_root_note() {
  local path="$1"
  [[ "$path" == */engineering/*.md ]] || return 1
  # Must not have another path segment after engineering/ (no subdir)
  local suffix="${path##*/engineering/}"
  [[ "$suffix" != */* ]] || return 1
  # Exclude generated files
  local base="${suffix%.md}"
  [[ "$base" != "INDEX" && "$base" != "DOMAIN_MAP" ]] || return 1
}

if [[ "$tool_name" == "Read" ]]; then
  file_path=$(echo "$event" | jq -r '.tool_input.file_path // empty')
  is_root_note "$file_path" && notes+=("$file_path")

elif [[ "$tool_name" == "Bash" ]]; then
  command=$(echo "$event" | jq -r '.tool_input.command // empty')

  if echo "$command" | grep -qE '\bkb-search\b'; then
    output=$(echo "$event" | jq -r '
      if (.tool_response | type) == "string" then .tool_response
      elif .tool_response.content then
        [.tool_response.content[] | select(.type == "text") | .text] | join("")
      else "" end
    ' 2>/dev/null)
    while IFS= read -r path; do
      [[ -n "$path" ]] && is_root_note "$path" && notes+=("$path")
    done < <(echo "$output" | grep -oE '[^ ]+/engineering/[^ /]+\.md' || true)

  elif echo "$command" | grep -qE '\bkb-peek\b'; then
    note_path=$(echo "$command" | grep -oE '[^ ]+/engineering/[^ /]+\.md' | head -1 || true)
    [[ -n "$note_path" ]] && is_root_note "$note_path" && notes+=("$note_path")
  fi
fi

[[ ${#notes[@]} -eq 0 ]] && exit 0

mkdir -p "$METADATA_DIR"
[[ -f "$READS_FILE" ]] || echo '{}' > "$READS_FILE"

ts=$(date -u +%Y-%m-%dT%H:%M:%SZ)

for note_path in "${notes[@]}"; do
  note_id=$(basename "$note_path" .md)
  tmp=$(mktemp)
  jq --arg id "$note_id" --arg ts "$ts" '
    .[$id] = {
      count: ((.[$id].count // 0) + 1),
      last_read: $ts
    }
  ' "$READS_FILE" > "$tmp" && mv "$tmp" "$READS_FILE"
done
