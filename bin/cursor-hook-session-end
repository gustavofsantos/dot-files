#!/usr/bin/env bash
# cursor-hook-session-end — sessionEnd hook: mark a Cursor session as ended.
#
# Invoked via hooks-runner for the cursor harness:
#   "sessionEnd": hooks-runner cursor sessionEnd
#
# Receives the CanonicalEvent envelope on stdin (built by hooks-runner).
# Mirror of claude-hook-session-end: keeps the state file (recent history) but
# flips status so `claude-sessions` shows it as ended, not a live pane.

set -euo pipefail

INPUT=$(cat 2>/dev/null || true)
SESSIONS_DIR="${CLAUDE_SESSIONS_DIR:-${HOME}/.claude-sessions}"
command -v jq &>/dev/null || exit 0

# Read session_id from the envelope; fall back to raw Cursor field for direct
# invocations without the runner.
SESSION_ID="$(printf '%s' "$INPUT" | jq -r '.session_id // empty' 2>/dev/null)"
[[ -z "$SESSION_ID" ]] && SESSION_ID="$(printf '%s' "$INPUT" | jq -r '.raw.conversation_id // empty' 2>/dev/null)"
[[ -z "$SESSION_ID" ]] && SESSION_ID="$(printf '%s' "$INPUT" | jq -r '.conversation_id // empty' 2>/dev/null)"
[[ -z "$SESSION_ID" ]] && exit 0

STATE="${SESSIONS_DIR}/${SESSION_ID}.json"
[[ -f "$STATE" ]] || exit 0

NOW=$(date +%s)
TMP=$(mktemp)
jq --argjson ts "$NOW" '.status = "ended" | .last_activity = $ts | .pane = ""' \
  "$STATE" > "$TMP" && mv "$TMP" "$STATE"

exit 0
