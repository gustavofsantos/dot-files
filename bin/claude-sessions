#!/usr/bin/env python3
"""
claude-sessions — interactive fzf picker for live AI coding sessions in tmux.

Usage:
  claude-sessions          # fzf picker → jump to the agent's pane on Enter
  claude-sessions --list   # print sessions to stdout and exit

Discovery is entirely process-based: there is NO state file and NO hook to
keep in sync. Every tmux pane is inspected for a running agent CLI (Claude
Code, Cursor Agent, aider, codex, …) by walking the pane's process subtree.
A session exists exactly when its process is alive, so the list can never go
stale and needs no configuration — a bare `claude` in any pane just shows up.

Add a new agent by extending AGENTS below.

Keybindings in fzf:
  Enter   jump to the agent's pane
  Esc/q   dismiss
"""

import os
import subprocess
import sys
from collections import defaultdict, deque

# (tag, display name, [executable basenames to match]).
# Matched against a pane's foreground command and its whole process subtree,
# so both `exec claude` and shell→claude layouts are found.
AGENTS = [
    ("cc", "claude",   ["claude"]),
    ("cu", "cursor",   ["cursor-agent"]),
    ("ai", "aider",    ["aider"]),
    ("cx", "codex",    ["codex"]),
    ("gm", "gemini",   ["gemini"]),
    ("go", "goose",    ["goose"]),
    ("oc", "opencode", ["opencode"]),
]
# Interpreters that may launch an agent as their script argument
# (e.g. `node /usr/local/bin/claude`). We inspect only the script token, so a
# flag value like `--model claude-opus-4-8` never counts as a match.
INTERPRETERS = {"node", "node22", "bun", "deno", "python", "python3", "ruby"}

WAIT_MARK = "⊡"  # window-name prefix set by the notify hook while waiting

GREEN  = "\033[0;32m"
YELLOW = "\033[0;33m"
DIM    = "\033[2m"
RESET  = "\033[0m"


def _basename(tok: str) -> str:
    return os.path.basename(tok.rstrip("/"))


def match_agent(args: str) -> tuple[str, str] | None:
    """Return (tag, name) if this argv looks like an agent CLI, else None."""
    toks = args.split()
    if not toks:
        return None
    b0 = _basename(toks[0])
    for tag, name, names in AGENTS:
        if b0 in names:
            return (tag, name)
    if b0 in INTERPRETERS:
        for tok in toks[1:]:
            if tok.startswith("-"):
                continue
            b = _basename(tok)
            for tag, name, names in AGENTS:
                if b in names:
                    return (tag, name)
            break  # only the first non-flag token is the script
    return None


def read_processes() -> tuple[dict[int, dict], dict[int, list[int]]]:
    """Snapshot the process table: pid -> {ppid, etime, args}, and children map."""
    procs: dict[int, dict] = {}
    children: dict[int, list[int]] = defaultdict(list)
    for flags in (["-axww"], ["-eww"], ["ax"]):
        try:
            out = subprocess.check_output(
                ["ps", *flags, "-o", "pid=,ppid=,etime=,args="],
                stderr=subprocess.DEVNULL, text=True,
            )
            break
        except (subprocess.CalledProcessError, FileNotFoundError):
            out = ""
    for line in out.splitlines():
        parts = line.split(None, 3)
        if len(parts) < 4:
            continue
        try:
            pid, ppid = int(parts[0]), int(parts[1])
        except ValueError:
            continue
        procs[pid] = {"ppid": ppid, "etime": etime_to_secs(parts[2]), "args": parts[3]}
        children[ppid].append(pid)
    return procs, children


def etime_to_secs(e: str) -> int:
    """Parse ps etime ([[DD-]HH:]MM:SS) into seconds."""
    e = e.strip()
    days = 0
    if "-" in e:
        d, e = e.split("-", 1)
        try:
            days = int(d)
        except ValueError:
            days = 0
    try:
        nums = [int(p) for p in e.split(":")]
    except ValueError:
        return 0
    while len(nums) < 3:
        nums.insert(0, 0)
    h, m, s = nums[-3], nums[-2], nums[-1]
    return days * 86400 + h * 3600 + m * 60 + s


def find_agent(pane_pid: int, current_cmd: str,
               procs: dict[int, dict], children: dict[int, list[int]]):
    """Locate an agent in a pane: search the process subtree, then fall back to
    the pane's foreground command. Returns (pid, tag, name) or None."""
    seen: set[int] = set()
    q: deque[int] = deque([pane_pid])
    while q:  # BFS returns the shallowest agent (the pane's own, not a subagent)
        pid = q.popleft()
        if pid in seen:
            continue
        seen.add(pid)
        p = procs.get(pid)
        if p:
            m = match_agent(p["args"])
            if m:
                return (pid, m[0], m[1])
        q.extend(children.get(pid, []))
    # Fallback: tmux's reported foreground command (survives a ps snapshot race).
    b = _basename(current_cmd)
    for tag, name, names in AGENTS:
        if b in names:
            return (pane_pid, tag, name)
    return None


def tmux_panes() -> list[dict]:
    fmt = "\t".join([
        "#{pane_id}", "#{pane_pid}", "#{pane_current_command}",
        "#{pane_current_path}", "#{session_name}", "#{window_index}",
        "#{window_name}",
    ])
    try:
        out = subprocess.check_output(
            ["tmux", "list-panes", "-a", "-F", fmt],
            stderr=subprocess.DEVNULL, text=True,
        )
    except (subprocess.CalledProcessError, FileNotFoundError):
        return []
    panes = []
    for line in out.strip().splitlines():
        f = line.split("\t")
        if len(f) < 7:
            continue
        panes.append({
            "pane": f[0], "pid": f[1], "cmd": f[2], "dir": f[3],
            "session": f[4], "window": f[5], "window_name": f[6],
        })
    return panes


def discover() -> list[dict]:
    procs, children = read_processes()
    sessions = []
    for p in tmux_panes():
        try:
            pane_pid = int(p["pid"])
        except ValueError:
            continue
        hit = find_agent(pane_pid, p["cmd"], procs, children)
        if not hit:
            continue
        pid, tag, name = hit
        wname = p["window_name"]
        waiting = wname.startswith(WAIT_MARK)
        label = wname[len(WAIT_MARK):].strip() if waiting else wname
        if not label or label in ("claude", name):
            label = os.path.basename(p["dir"]) or name
        sessions.append({
            "pane": p["pane"], "tag": tag, "agent": name,
            "session": p["session"], "window": p["window"],
            "label": label, "dir": p["dir"],
            "waiting": waiting,
            "age": procs.get(pid, {}).get("etime", 0),
        })
    # Waiting sessions (need attention) first, then most-recently-started.
    sessions.sort(key=lambda s: (not s["waiting"], s["age"]))
    return sessions


def age(secs: int) -> str:
    if secs < 60:    return f"{secs}s"
    if secs < 3600:  return f"{secs // 60}m"
    if secs < 86400: return f"{secs // 3600}h"
    return f"{secs // 86400}d"


def render_line(s: dict) -> str:
    dot    = f"{YELLOW}●{RESET}" if s["waiting"] else f"{GREEN}●{RESET}"
    tag    = f"{DIM}{s['tag']}{RESET}"
    name   = s["label"][:36]
    status = f"{YELLOW}waiting{RESET}" if s["waiting"] else f"{GREEN}active{RESET}"
    loc    = f"{s['session']}:{s['window']}"
    dirs   = f"{DIM}{s['dir']}{RESET}"
    return f"{dot} {tag}  {name:<38}  {status:<18}  {age(s['age']):<5}  {loc:<20}  {dirs}"


def run_fzf(sessions: list[dict]) -> dict | None:
    # Each line is "<pane_id>\t<rendered>"; fzf shows fields 2.. and passes
    # field 1 to the preview, so the selection carries the pane id.
    by_pane = {s["pane"]: s for s in sessions}
    lines = [f"{s['pane']}\t{render_line(s)}" for s in sessions]
    try:
        r = subprocess.run(
            ["fzf", "--ansi", "--no-sort", "--reverse", "--border=rounded",
             "--delimiter=\t", "--with-nth=2..",
             "--prompt=  agents › ", "--header=Enter: jump to agent   Esc: dismiss",
             "--height=100%", "--margin=1,2",
             "--preview", "claude-session-preview {1}",
             "--preview-window", "right:50%:wrap"],
            input="\n".join(lines).encode(),
            capture_output=True,
        )
    except FileNotFoundError:
        print("fzf not found. Install: brew install fzf", file=sys.stderr)
        sys.exit(1)
    if r.returncode != 0:
        return None
    pane = r.stdout.decode().split("\t", 1)[0].strip()
    return by_pane.get(pane)


def pane_exists(pane: str) -> bool:
    try:
        out = subprocess.check_output(
            ["tmux", "list-panes", "-a", "-F", "#{pane_id}"],
            stderr=subprocess.DEVNULL, text=True,
        )
        return pane in out.split()
    except (subprocess.CalledProcessError, FileNotFoundError):
        return False


def pane_session(pane: str) -> str | None:
    try:
        out = subprocess.check_output(
            ["tmux", "display-message", "-p", "-t", pane, "#{session_name}"],
            stderr=subprocess.DEVNULL, text=True,
        )
        return out.strip() or None
    except (subprocess.CalledProcessError, FileNotFoundError):
        return None


def attach(s: dict) -> None:
    pane = s["pane"]
    if not pane_exists(pane):
        print(f"Session '{s['label']}' is no longer live.", file=sys.stderr)
        sys.exit(1)
    session = pane_session(pane)
    if not session:
        print(f"Pane {pane} vanished.", file=sys.stderr)
        sys.exit(1)
    if os.environ.get("TMUX"):
        subprocess.run(["tmux", "switch-client", "-t", session], stderr=subprocess.DEVNULL)
        subprocess.run(["tmux", "select-window", "-t", pane], stderr=subprocess.DEVNULL)
        subprocess.run(["tmux", "select-pane", "-t", pane], stderr=subprocess.DEVNULL)
    else:
        subprocess.run(["tmux", "select-window", "-t", pane], stderr=subprocess.DEVNULL)
        subprocess.run(["tmux", "select-pane", "-t", pane], stderr=subprocess.DEVNULL)
        os.execvp("tmux", ["tmux", "attach-session", "-t", session])


def main() -> None:
    sessions = discover()

    if not sessions:
        print("No live agent sessions found.")
        sys.exit(0)

    if "--list" in sys.argv:
        for s in sessions:
            print(render_line(s))
        sys.exit(0)

    selected = run_fzf(sessions)
    if selected:
        attach(selected)


if __name__ == "__main__":
    main()
