#!/usr/bin/env python3
"""
claude-sessions — interactive fzf picker for tracked Claude Code sessions.

Usage:
  claude-sessions          # fzf picker → attach on Enter
  claude-sessions --list   # print sessions to stdout and exit

State files live in ~/.claude-sessions/<CLAUDE_SESSION_ID>.json (written by
claude-hook-notify). Each file records: session_id, track_name, task, dir,
status, started_at, last_activity, notifications.

The track_name field matches the tmux session name created by claude-run.
Untracked tmux sessions whose names start with "claude-" are also surfaced.

Keybindings in fzf:
  Enter   attach to selected session
  Esc/q   dismiss
"""

import json
import os
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path

SESSIONS_DIR = Path(os.environ.get("CLAUDE_SESSIONS_DIR", "")).expanduser() \
    or Path.home() / ".claude-sessions"

GREEN  = "\033[0;32m"
YELLOW = "\033[0;33m"
RED    = "\033[0;31m"
DIM    = "\033[2m"
RESET  = "\033[0m"
ALIVE  = f"{GREEN}●{RESET}"
DEAD   = f"{DIM}○{RESET}"

STATUS_ORDER = {"running": 0, "waiting": 1, "gone": 2, "done": 3, "unknown": 4}
STATUS_COLOR = {
    "running": f"{GREEN}running{RESET}",
    "waiting": f"{YELLOW}waiting{RESET}",
    "gone":    f"{DIM}gone{RESET}",
    "done":    f"{DIM}done{RESET}",
    "unknown": f"{DIM}?{RESET}",
}


def tmux_live_sessions() -> set[str]:
    try:
        out = subprocess.check_output(
            ["tmux", "list-sessions", "-F", "#{session_name}"],
            stderr=subprocess.DEVNULL, text=True,
        )
        return set(out.strip().splitlines())
    except (subprocess.CalledProcessError, FileNotFoundError):
        return set()


def age(ts: float) -> str:
    delta = int(datetime.now(timezone.utc).timestamp() - ts)
    if delta < 60:     return f"{delta}s"
    if delta < 3600:   return f"{delta // 60}m"
    if delta < 86400:  return f"{delta // 3600}h"
    return f"{delta // 86400}d"


def checks_summary(track_name: str) -> str:
    """Latest checks result as a short colored token (✓/✗/●), or ''."""
    try:
        r = subprocess.run(
            ["checks-status", track_name, "--oneline"],
            capture_output=True, text=True, timeout=3,
        )
    except (FileNotFoundError, subprocess.TimeoutExpired):
        return ""
    return r.stdout.strip()


def load_tracked(live: set[str]) -> list[dict]:
    if not SESSIONS_DIR.exists():
        return []
    sessions = []
    for path in sorted(SESSIONS_DIR.glob("*.json"), key=lambda p: p.stat().st_mtime, reverse=True):
        try:
            data = json.loads(path.read_text())
        except (json.JSONDecodeError, OSError):
            continue
        track_name = data.get("track_name") or path.stem
        is_alive   = track_name in live
        status     = data.get("status", "unknown")
        if not is_alive and status not in ("done",):
            status = "gone"
        sessions.append({
            "track_name":    track_name,
            "task":          data.get("task", ""),
            "status":        status,
            "alive":         is_alive,
            "pane":          data.get("pane", ""),
            "checks":        checks_summary(track_name),
            "last_ts":       float(data.get("last_activity") or data.get("started_at") or 0),
            "notifications": data.get("notifications", 0),
            "tracked":       True,
        })
    return sessions


def load_untracked(live: set[str], tracked_names: set[str]) -> list[dict]:
    sessions = []
    for name in live:
        if not name.startswith("claude-"):
            continue
        if name in tracked_names:
            continue
        sessions.append({
            "track_name":    name,
            "task":          "",
            "status":        "running",
            "alive":         True,
            "pane":          "",
            "checks":        checks_summary(name),
            "last_ts":       0.0,
            "notifications": 0,
            "tracked":       False,
        })
    return sessions


def render_line(s: dict) -> str:
    """Render the visible columns (the hidden track_name key is prepended in run_fzf)."""
    dot        = ALIVE if s["alive"] else DEAD
    name       = s["track_name"][:36]
    status_str = STATUS_COLOR.get(s["status"], s["status"])
    checks_str = s.get("checks") or f"{DIM}—{RESET}"
    age_str    = age(s["last_ts"]) if s["last_ts"] else "?"
    task_str   = (s["task"][:40] if s["task"] else f"{DIM}(untracked){RESET}") if not s["tracked"] \
                 else s["task"][:40]
    return f"{dot}  {name:<38}  {status_str:<24}  {checks_str:<16}  {age_str:<5}  {task_str}"


def run_fzf(sessions: list[dict]) -> dict | None:
    # Each line is "<track_name>\t<rendered>"; fzf shows fields 2.. and uses
    # field 1 for the preview command, so selection carries the name unambiguously.
    by_name = {s["track_name"]: s for s in sessions}
    lines   = [f"{s['track_name']}\t{render_line(s)}" for s in sessions]
    try:
        r = subprocess.run(
            ["fzf", "--ansi", "--no-sort", "--reverse", "--border=rounded",
             "--delimiter=\t", "--with-nth=2..",
             "--prompt=  claude › ", "--header=Enter: jump to agent   Esc: dismiss",
             "--height=100%", "--margin=1,2",
             "--preview", "claude-session-preview {1}",
             "--preview-window", "right:50%:wrap"],
            input="\n".join(lines).encode(),
            capture_output=True,
        )
    except FileNotFoundError:
        print("fzf not found. Install: brew install fzf", file=sys.stderr)
        sys.exit(1)
    if r.returncode != 0:
        return None
    name = r.stdout.decode().split("\t", 1)[0].strip()
    return by_name.get(name)


def attach(s: dict, live: set[str]) -> None:
    track_name, pane = s["track_name"], s.get("pane", "")
    if track_name not in live:
        print(f"Session '{track_name}' is no longer active.", file=sys.stderr)
        sys.exit(1)

    # Jump straight to the agent's pane when we recorded one; otherwise the session.
    def select_pane() -> None:
        if pane:
            subprocess.run(["tmux", "select-window", "-t", pane],
                           stderr=subprocess.DEVNULL)
            subprocess.run(["tmux", "select-pane", "-t", pane],
                           stderr=subprocess.DEVNULL)

    if os.environ.get("TMUX"):
        subprocess.run(["tmux", "switch-client", "-t", track_name])
        select_pane()
    else:
        select_pane()
        os.execvp("tmux", ["tmux", "attach-session", "-t", track_name])


def main() -> None:
    list_only = "--list" in sys.argv
    live      = tmux_live_sessions()
    tracked   = load_tracked(live)
    named     = {s["track_name"] for s in tracked}
    sessions  = tracked + load_untracked(live, named)
    sessions.sort(key=lambda s: (STATUS_ORDER.get(s["status"], 99), -s["last_ts"]))

    if not sessions:
        print("No tracked Claude sessions found.")
        sys.exit(0)

    if list_only:
        for s in sessions:
            print(render_line(s))
        sys.exit(0)

    selected = run_fzf(sessions)
    if selected:
        attach(selected, live)


if __name__ == "__main__":
    main()
