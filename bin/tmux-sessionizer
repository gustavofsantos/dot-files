#!/usr/bin/env bash

paths=(
    "$HOME/.dot-files"
    "$HOME/.config/nvim"
    "$HOME/.config/ghostty"
)

sessions_only=false
if [[ "$1" == "--sessions-only" || "$1" == "-s" ]]; then
    sessions_only=true
    shift
fi

if [[ $# -eq 1 ]]; then
    selected=$1
else
    _preview='if tmux has-session -t {} 2>/dev/null; then
                if [[ {} == claude-* ]]; then
                  claude-session-preview {}
                else
                  tmux list-windows -t {} -F "  #{window_index}  #{window_name}"
                fi
              elif [[ -d {} ]]; then
                ls -1 {} | head -20
              fi'

    if [[ "$sessions_only" == true ]]; then
        items=$(tmux ls -F "#{session_name}" 2>/dev/null)
    else
        items=$( (
            tmux ls -F "#{session_name}" 2>/dev/null
            for path in "${paths[@]}"; do
                echo "$path"
            done
            find ~/Workplace -mindepth 1 -maxdepth 1 -type d 2>/dev/null
            find ~/Workplace/seubarriga-worktrees -mindepth 1 -maxdepth 1 -type d 2>/dev/null
            find ~/Workplace/backend-services/applications -mindepth 1 -maxdepth 1 -type d 2>/dev/null
        ) )
    fi

    current_session=$(tmux display-message -p '#S' 2>/dev/null)
    pos=1
    if [[ -n "$current_session" ]]; then
        line_num=$(echo "$items" | grep -n -x -F "$current_session" | head -n 1 | cut -d: -f1)
        if [[ -n "$line_num" ]]; then
            pos=$line_num
        fi
    fi

    selected=$(echo "$items" | fzf --height 100% --prompt='→ ' --select-1 --exit-0 \
          --preview-window 'right:40%' \
          --preview "$_preview" \
          --bind "start:pos($pos)")
fi

if [[ -z $selected ]]; then
    exit 0
fi

generate_session_name() {
    local selected_path="$1"
    local parent_dir=$(basename "$(dirname "$selected_path")")

    if [[ "$parent_dir" == *-worktrees ]]; then
        local project_name=${parent_dir%-worktrees}
        local branch_name=$(basename "$selected_path" | tr . _)
        echo "${project_name}-${branch_name}"
    else
        echo "$(basename "$selected_path" | tr . _)"
    fi
}

selected_name=$(generate_session_name "$selected")
tmux_running=$(pgrep tmux)

if [[ -z $TMUX ]] && [[ -z $tmux_running ]]; then
    tmux new-session -s $selected_name -c $selected
    exit 0
fi

if ! tmux has-session -t=$selected_name 2>/dev/null; then
    tmux new-session -ds $selected_name -c $selected
fi

tmux switch-client -t $selected_name
