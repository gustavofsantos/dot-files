#!/usr/bin/env bash
# claude-session-preview — rich fzf preview for a live agent session.
# Usage: claude-session-preview <pane-id>
# Called from claude-sessions' fzf --preview hook.
#
# Everything shown is derived live from tmux — no state files, no hooks. The
# pane's location, working dir and foreground command come from tmux, and the
# body is a live capture of the pane so you see exactly what the agent is doing.

PANE="${1:-}"
[[ -z "$PANE" ]] && exit 0

DIM='\033[2m'; BOLD='\033[1m'; RESET='\033[0m'

# Live pane metadata (blank if the pane vanished between listing and preview).
# Query fields one at a time — tmux format strings can't embed a tab delimiter.
q() { tmux display-message -p -t "$PANE" "$1" 2>/dev/null; }
loc=$(q '#{session_name}:#{window_index}.#{pane_index}')
if [[ -z "$loc" ]]; then
  printf "${DIM}(pane %s no longer exists)${RESET}\n" "$PANE"
  exit 0
fi
dir=$(q '#{pane_current_path}')
cmd=$(q '#{pane_current_command}')
wname=$(q '#{window_name}')

printf "window  %s\n" "$wname"
printf "at      %s\n" "$loc"
printf "cmd     %s\n" "$cmd"
[[ -n "$dir" ]] && printf "dir     %s\n" "$dir"

# Latest checks result for this repo, if the checks tooling is installed.
if command -v checks-status &>/dev/null && [[ -n "$dir" ]]; then
  out=$(cd "$dir" 2>/dev/null && checks-status 2>/dev/null)
  if [[ -n "$out" ]]; then
    printf "\n${BOLD}checks${RESET}\n"
    printf "%s\n" "$out" | sed 's/^/  /'
  fi
fi

# Live capture of the agent pane — the always-fresh source of truth.
printf "\n${BOLD}── agent pane ──${RESET}\n"
tmux capture-pane -p -t "$PANE" 2>/dev/null | tail -n 40 \
  || printf "${DIM}(pane %s no longer exists)${RESET}\n" "$PANE"
