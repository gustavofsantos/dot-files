#!/usr/bin/env bash
# claude-session-preview — rich fzf preview for a Claude Code session.
# Usage: claude-session-preview <session-id>
# Called from claude-sessions' fzf --preview hook.
#
# Shows: task/status/dir, the latest checks result for the session (if any),
# and a live capture of the agent's pane.

SID="${1:-}"
[[ -z "$SID" ]] && exit 0

SESSIONS_DIR="${CLAUDE_SESSIONS_DIR:-${HOME}/.claude-sessions}"
STATE="${SESSIONS_DIR}/${SID}.json"

DIM='\033[2m'; BOLD='\033[1m'; RESET='\033[0m'

PANE=""
if [[ -f "$STATE" ]] && command -v jq &>/dev/null; then
  name=$(jq -r '.track_name // ""' "$STATE")
  task=$(jq -r '.task // ""' "$STATE")
  status=$(jq -r '.status // "unknown"' "$STATE")
  dir=$(jq -r '.dir // ""' "$STATE")
  notifs=$(jq -r '.notifications // 0' "$STATE")
  PANE=$(jq -r '.pane // ""' "$STATE")

  [[ -n "$name" ]]   && printf "name    %s\n" "$name"
  [[ -n "$task" ]]   && printf "task    %s\n" "$task"
  printf "status  %s\n" "$status"
  [[ -n "$dir" ]]    && printf "dir     %s\n" "$dir"
  (( notifs > 0 ))   && printf "notifs  %d\n" "$notifs"
fi

# Latest checks result for this session (best-effort — blank if none).
if command -v checks-status &>/dev/null; then
  out=$(checks-status "$SID" 2>/dev/null)
  if [[ -n "$out" ]]; then
    printf "\n${BOLD}checks${RESET}\n"
    printf "%s\n" "$out" | sed 's/^/  /'
  fi
fi

# Live capture of the agent pane.
printf "\n${DIM}── agent pane ──${RESET}\n"
if [[ -n "$PANE" ]]; then
  tmux capture-pane -p -t "$PANE" 2>/dev/null | tail -n 30 \
    || printf "${DIM}(pane %s no longer exists)${RESET}\n" "$PANE"
fi
