#!/usr/bin/env bash
# claude-hook-vault-lint — PostToolUse hook for ~/engineering/ facts
#
# Claude Code wires this as:
#   "PostToolUse": [{ "matcher": "Write|Edit|MultiEdit", "command": "bash ~/.claude/hooks/vault-lint.sh" }]
#
# Input:  JSON from stdin  { tool_name, tool_input: { path, ... } }
# Output: violation messages to stdout
# Exit:   0 = ok | 2 = violations found (Claude Code shows output to Claude)

INPUT=$(cat)
TOOL=$(printf '%s' "$INPUT" | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('tool_name',''))")
FILE=$(printf '%s' "$INPUT" | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('tool_input',{}).get('path',''))")
VAULT="$HOME/engineering"

# ── Scope guard ───────────────────────────────────────────────────────────────
# Only act on file-writing tools
case "$TOOL" in Write | Edit | MultiEdit) ;; *) exit 0 ;; esac

# Only .md files inside the vault
[[ -z "$FILE" || "$FILE" != "$VAULT/"* || "$FILE" != *.md ]] && exit 0

# Only root-level files — any path with a second segment is issues/ or spikes/
RELATIVE="${FILE#$VAULT/}"
[[ "$RELATIVE" == */* ]] && exit 0

[[ ! -f "$FILE" ]] && exit 0

# ── Validation functions ──────────────────────────────────────────────────────

ERRORS=()
CONTENT=$(cat "$FILE")
STEM=$(basename "$FILE" .md | tr '-' ' ')

check_word_count() {
  local words
  words=$(printf '%s' "$CONTENT" | wc -w | tr -d ' ')
  (( words > 150 )) && ERRORS+=("word count: $words / 150 — split into a second fact")
}

check_wikilink() {
  printf '%s' "$CONTENT" | grep -q '\[\[' \
    || ERRORS+=("no [[wikilink]] — every fact must connect to at least one other note")
}

check_no_headers() {
  printf '%s' "$CONTENT" | grep -qE '^#{1,6} ' \
    && ERRORS+=("contains markdown headers — a fact is one idea, no sections")
}

check_claim_filename() {
  local verbs="is|are|was|were|makes|breaks|causes|enables|prevents|decouples|\
couples|requires|allows|forces|hides|exposes|reduces|increases|serializes|\
propagates|isolates|composes|violates|enforces|leaks|separates|wraps|\
delegates|blocks|mutates|defers|resolves|collapses|aggregates|converts|maps"
  printf '%s' "$STEM" | grep -qwE "$verbs" \
    || ERRORS+=("filename '$(basename "$FILE")' is not a claim — add a verb")
}

# ── Run ───────────────────────────────────────────────────────────────────────

check_word_count
check_wikilink
check_no_headers
check_claim_filename

# ── Output ────────────────────────────────────────────────────────────────────

(( ${#ERRORS[@]} == 0 )) && exit 0

printf 'vault: fact constraint violations in %s\n' "$(basename "$FILE")"
for e in "${ERRORS[@]}"; do
  printf '  · %s\n' "$e"
done

exit 2  # non-blocking: Claude Code shows output to Claude and expects a fix
