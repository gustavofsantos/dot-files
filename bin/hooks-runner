#!/usr/bin/env ruby
# hooks-runner <harness> <event> — central hook dispatcher.
#
# Reads the raw event payload on stdin, normalises it into a CanonicalEvent
# envelope, exports HOOK_HARNESS and HOOK_EVENT, looks up matching hooks from
# ~/.agent-hooks.yml (+ local overlay), and runs each one with the envelope on
# stdin.
#
# Two kinds of hook:
#   - Observers (default): stdout is suppressed, exit code ignored; they only
#     watch. The runner stays neutral for them (exit 0, no stdout).
#   - Decision hooks (`decision: true` in the registry): their stdout is parsed
#     as a canonical decision — {"decision":"block"|"allow", "reason", "context"}.
#     The runner picks the first block (registry order) and translates it into
#     the *native* contract of the invoking harness (output adapter):
#       Claude tool_pre     -> stdout permissionDecision:"deny"
#       Claude turn_end      -> stdout decision:"block" (+ additionalContext)
#       Claude prompt_submit -> stdout decision:"block" (+ additionalContext)
#       Cursor tool_pre      -> stdout permission:"deny" (agentMessage/userMessage)
#       Cursor prompt_submit -> stdout continue:false
#       Cursor turn_end      -> cannot block (its stop hook is observe-only);
#                               the decision is dropped with a logged note.
# When no decision hook blocks, the runner stays neutral (exit 0, no stdout),
# exactly as before — so observers are unaffected.
#
# See CLAUDE.md ("agent-hooks" / "GitButler provenance hooks") for envelope
# shape, registry format, the decision protocol, and dispatch logging.

require "digest"
require "fileutils"
require "json"
require "open3"
require "time"
require "yaml"

CANONICAL_EVENTS = {
  %w[claude Stop] => "turn_end",
  %w[claude SessionStart] => "session_start",
  %w[claude UserPromptSubmit] => "prompt_submit",
  %w[claude SessionEnd] => "session_end",
  %w[claude Notification] => "notification",
  %w[claude PreToolUse] => "tool_pre",
  %w[cursor stop] => "turn_end",
  %w[cursor sessionStart] => "session_start",
  %w[cursor beforeSubmitPrompt] => "prompt_submit",
  %w[cursor sessionEnd] => "session_end",
  %w[cursor beforeShellExecution] => "tool_pre",
  %w[cursor beforeMCPExecution] => "tool_pre",
}.freeze

def home
  ENV.fetch("HOME", Dir.home)
end

def xdg_cache
  ENV.fetch("XDG_CACHE_HOME", File.join(home, ".cache"))
end

def xdg_data
  ENV.fetch("XDG_DATA_HOME", File.join(home, ".local", "share"))
end

def canonical_event(harness, raw_event)
  CANONICAL_EVENTS.fetch([harness, raw_event], raw_event)
end

def parse_json_payload(payload)
  return {} if payload.nil? || payload.strip.empty?

  parsed = JSON.parse(payload)
  parsed.is_a?(Hash) ? parsed : {}
rescue JSON::ParserError
  {}
end

def build_envelope(harness, canonical, raw_event, payload)
  raw = parse_json_payload(payload)

  envelope = {
    "harness" => harness,
    "event" => canonical,
    "raw_event" => raw_event,
    "tool" => nil,
    "raw" => raw,
  }

  case harness
  when "claude"
    envelope.merge!(
      "session_id" => raw["session_id"],
      "cwd" => raw["cwd"],
      "transcript_path" => raw["transcript_path"],
      "model" => raw["model"],
      "prompt" => raw["prompt"],
      "tool" => raw["tool_name"],
      "tool_input" => raw["tool_input"]
    )
  when "cursor"
    roots = raw["workspace_roots"]
    roots = [] unless roots.is_a?(Array)
    envelope.merge!(
      "session_id" => raw["conversation_id"],
      "cwd" => roots[0],
      "transcript_path" => nil,
      "model" => nil,
      "prompt" => raw["prompt"]
    )
    envelope.merge!(cursor_tool_fields(raw_event, raw))
  else
    envelope.merge!(
      "session_id" => nil,
      "cwd" => nil,
      "transcript_path" => nil,
      "model" => nil,
      "prompt" => nil
    )
  end

  JSON.generate(envelope)
end

# Normalise a Cursor tool event into the same tool/tool_input shape a Claude
# PreToolUse payload carries, so a decision hook can read .tool_input.command
# regardless of harness.
def cursor_tool_fields(raw_event, raw)
  case raw_event
  when "beforeShellExecution"
    { "tool" => "Bash", "tool_input" => { "command" => raw["command"] } }
  when "beforeMCPExecution"
    { "tool" => raw["tool_name"] || "mcp", "tool_input" => raw["tool_input"] || raw }
  else
    {}
  end
end

def file_stamp(path)
  return "0:0" unless File.file?(path)

  stat = File.stat(path)
  "#{stat.mtime.to_i}:#{stat.size}"
end

def registry_stamp(base_config, local_config)
  "#{file_stamp(base_config)}|#{file_stamp(local_config)}"
end

def cache_key(base_config, local_config)
  Digest::SHA256.hexdigest("#{base_config}|#{local_config}")[0, 16]
end

def normalize_hook(hook)
  return hook unless hook.is_a?(Hash)

  hook.each_with_object({}) do |(key, value), normalized|
    normalized[key == true ? "on" : key.to_s] = value
  end
end

def load_hooks_yaml(path)
  return [] unless File.file?(path)

  data = YAML.safe_load_file(path, permitted_classes: [Date, Time], aliases: true) || {}
  hooks = data["hooks"] || []
  return [] unless hooks.is_a?(Array)

  hooks.map { |h| normalize_hook(h) }
rescue StandardError
  []
end

def merge_hooks(base_config, local_config)
  base = load_hooks_yaml(base_config)
  local = File.file?(local_config) ? load_hooks_yaml(local_config) : []
  local_names = local.filter_map { |h| h["name"] if h.is_a?(Hash) }
  merged = base.select { |h| h.is_a?(Hash) && !local_names.include?(h["name"]) }
  merged.concat(local.select { |h| h.is_a?(Hash) })
  merged
end

def load_hooks(base_config, local_config, cache_dir)
  stamp = registry_stamp(base_config, local_config)
  cache_file = File.join(cache_dir, "#{cache_key(base_config, local_config)}.json")

  begin
    FileUtils.mkdir_p(cache_dir)
  rescue StandardError
    cache_file = nil
  end

  if cache_file && File.file?(cache_file)
    begin
      lines = File.read(cache_file).lines
      if !lines.empty? && lines[0].strip == stamp
        hooks = JSON.parse(lines[1..].join)
        return hooks if hooks.is_a?(Array)
      end
    rescue StandardError
      # fall through to reload
    end
  end

  hooks = merge_hooks(base_config, local_config)

  if cache_file
    begin
      tmp = "#{cache_file}.#{Process.pid}.tmp"
      File.write(tmp, "#{stamp}\n#{JSON.generate(hooks)}")
      File.rename(tmp, cache_file)
    rescue StandardError
      File.delete(tmp) if defined?(tmp) && File.exist?(tmp)
    end
  end

  hooks
end

def hook_matches?(hook, canonical_event_name, harness)
  on = hook["on"] || []
  return false unless on.include?(canonical_event_name)

  enabled = hook.key?("enabled") ? hook["enabled"] : true
  return false unless enabled == true

  harness_filter = hook["harness"]
  return false if harness_filter.is_a?(Array) && !harness_filter.include?(harness)

  true
end

def select_hooks(hooks, canonical_event_name, harness)
  hooks.select { |h| h.is_a?(Hash) && hook_matches?(h, canonical_event_name, harness) }
end

def log_session_id(envelope_json)
  envelope = JSON.parse(envelope_json)
  sid = envelope["session_id"]
  sid && !sid.to_s.empty? ? sid.to_s : "unknown"
rescue JSON::ParserError
  "unknown"
end

def write_json_atomic(path, data)
  tmp = "#{path}.#{Process.pid}.tmp"
  File.write(tmp, JSON.pretty_generate(data))
  File.rename(tmp, path)
  true
rescue StandardError
  File.delete(tmp) if defined?(tmp) && File.exist?(tmp)
  false
end

def run_hook(command, envelope, env)
  started = Process.clock_gettime(Process::CLOCK_MONOTONIC)
  stdout, stderr, status = Open3.capture3(env, "bash", "-c", command, stdin_data: envelope)
  duration_ms = ((Process.clock_gettime(Process::CLOCK_MONOTONIC) - started) * 1000).to_i
  # Hooks emit UTF-8 (decision reasons carry em/en dashes); capture3 hands back
  # bytes tagged with the external encoding, so retag before any string op.
  [status.exitstatus, stdout.force_encoding("UTF-8"), stderr.force_encoding("UTF-8"), duration_ms]
rescue StandardError => e
  duration_ms = ((Process.clock_gettime(Process::CLOCK_MONOTONIC) - started) * 1000).to_i
  [1, "", e.message, duration_ms]
end

# Parse a decision hook's stdout into a canonical decision, or nil if it emitted
# nothing parseable (treated as "no decision" → allow / defer). Recognised shape:
#   {"decision": "block"|"allow", "reason": "...", "context": "..."}
def parse_decision(stdout)
  return nil if stdout.nil? || stdout.strip.empty?

  parsed = JSON.parse(stdout)
  return nil unless parsed.is_a?(Hash)

  decision = parsed["decision"]
  return nil unless %w[block allow].include?(decision)

  {
    "decision" => decision,
    "reason" => parsed["reason"].to_s,
    "context" => parsed["context"].to_s,
  }
rescue JSON::ParserError
  nil
end

# Output adapter: translate a canonical block decision into the invoking
# harness's native contract, printing to stdout/stderr as required. Returns the
# process exit code to use. A block is always carried by stdout JSON (exit 0)
# where the harness supports it, so the runner keeps its neutral exit code.
def emit_block(harness, canonical, reason, context)
  reason = "blocked by hooks-runner" if reason.nil? || reason.empty?
  ctx = context.to_s.empty? ? nil : context.to_s

  case [harness, canonical]
  when %w[claude tool_pre]
    out = { "hookSpecificOutput" => {
      "hookEventName" => "PreToolUse",
      "permissionDecision" => "deny",
      "permissionDecisionReason" => reason,
    } }
    out["hookSpecificOutput"]["additionalContext"] = ctx if ctx
    puts JSON.generate(out)
    0
  when %w[cursor tool_pre]
    puts JSON.generate("permission" => "deny", "agentMessage" => reason, "userMessage" => reason)
    0
  when %w[claude turn_end], %w[claude prompt_submit]
    event_name = canonical == "turn_end" ? "Stop" : "UserPromptSubmit"
    out = { "decision" => "block", "reason" => reason }
    out["hookSpecificOutput"] = { "hookEventName" => event_name, "additionalContext" => ctx } if ctx
    puts JSON.generate(out)
    0
  when %w[cursor prompt_submit]
    puts JSON.generate("continue" => false, "agentMessage" => reason, "userMessage" => reason)
    0
  when %w[cursor turn_end]
    warn "hooks-runner: block decision dropped — Cursor's stop hook is observe-only (cannot block turn end): #{reason}"
    0
  else
    warn "hooks-runner: no decision translation for #{harness}/#{canonical}; ignoring block: #{reason}"
    0
  end
end

def tail_lines(text, n = 20)
  text.lines.last(n).join
end

def dispatch(harness, raw_event, payload, base_config, local_config, cache_dir, log_dir)
  canonical = canonical_event(harness, raw_event)
  ENV["HOOK_HARNESS"] = harness
  ENV["HOOK_EVENT"] = canonical

  hooks = load_hooks(base_config, local_config, cache_dir)
  return 0 if hooks.nil? || hooks.empty?

  matched = select_hooks(hooks, canonical, harness)
  return 0 if matched.empty?

  envelope = build_envelope(harness, canonical, raw_event, payload)
  envelope = payload if envelope.nil? || envelope.empty?

  session_id = log_session_id(envelope)
  started_at = Time.now.to_i
  log_file = nil

  begin
    session_log_dir = File.join(log_dir, session_id)
    FileUtils.mkdir_p(session_log_dir)
    log_file = File.join(session_log_dir, "#{started_at}-#{harness}-#{canonical}.json")
  rescue StandardError
    log_file = nil
  end

  trace = {
    "harness" => harness,
    "event" => canonical,
    "raw_event" => raw_event,
    "started_at" => started_at,
    "finished_at" => nil,
    "hooks" => matched.map do |h|
      {
        "name" => h["name"],
        "command" => h["command"],
        "status" => "running",
        "exit_code" => nil,
        "duration_ms" => nil,
        "output_tail" => nil,
      }
    end,
    "summary" => {
      "total" => matched.length,
      "passed" => 0,
      "failed" => 0,
      "status" => "running",
    },
  }

  log_file = nil unless log_file && write_json_atomic(log_file, trace)

  passed = 0
  failed = 0
  hook_env = ENV.to_h
  block = nil # first block decision wins (registry order)

  matched.each_with_index do |hook, i|
    command = hook["command"]
    next if command.nil? || command.to_s.empty?

    exit_code, stdout, stderr, duration_ms = run_hook(command.to_s, envelope, hook_env)
    is_decision = hook["decision"] == true

    # A decision hook's stdout is its verdict, not diagnostic noise — keep it out
    # of the re-emitted stderr. Everything else is suppressed as before.
    combined = is_decision ? stderr : "#{stdout}#{stderr}"

    if exit_code.zero?
      passed += 1
      status = "pass"
    else
      failed += 1
      status = "fail"
      warn combined.rstrip unless combined.nil? || combined.empty?
    end

    if is_decision && block.nil?
      decision = parse_decision(stdout)
      block = { "name" => hook["name"], "reason" => decision["reason"], "context" => decision["context"] } if decision && decision["decision"] == "block"
    end

    next unless log_file

    trace["hooks"][i].merge!(
      "status" => status,
      "exit_code" => exit_code,
      "duration_ms" => duration_ms,
      "output_tail" => tail_lines(combined)
    )
    trace["summary"]["passed"] = passed
    trace["summary"]["failed"] = failed
    write_json_atomic(log_file, trace)
  end

  if log_file
    trace["finished_at"] = Time.now.to_i
    trace["summary"]["status"] = failed.positive? ? "fail" : "pass"
    trace["summary"]["passed"] = passed
    trace["summary"]["failed"] = failed
    trace["summary"]["decision"] = block ? "block" : "allow"
    trace["summary"]["blocked_by"] = block ? block["name"] : nil
    write_json_atomic(log_file, trace)
  end

  return 0 unless block

  emit_block(harness, canonical, block["reason"], block["context"])
end

def main(argv)
  if argv.length < 2
    warn "usage: hooks-runner <harness> <event>"
    return 0
  end

  harness, raw_event = argv[0], argv[1]
  payload = $stdin.read

  base_config = ENV.fetch("AGENT_HOOKS_CONFIG", File.join(home, ".agent-hooks.yml"))
  return 0 unless File.file?(base_config)

  local_config = ENV.fetch("AGENT_HOOKS_CONFIG_LOCAL", File.join(home, ".agent-hooks.local.yml"))
  cache_dir = ENV.fetch("AGENT_HOOKS_CACHE_DIR", File.join(xdg_cache, "agent-hooks"))
  log_dir = ENV.fetch("AGENT_HOOKS_LOG_DIR", File.join(xdg_data, "agent-hooks", "logs"))

  exit_code = dispatch(harness, raw_event, payload, base_config, local_config, cache_dir, log_dir)
  exit_code.is_a?(Integer) ? exit_code : 0
end

if File.realpath($PROGRAM_NAME) == File.realpath(__FILE__)
  exit(main(ARGV))
end
