#!/usr/bin/env python3
"""
painter-card-create — scaffold a new painter card

Usage:
    painter-card-create --title "Fix auth bug" [--status inbox] [--tags feature,api]
"""

import argparse
import json
import os
import re
import sys
from datetime import date
from pathlib import Path

PAINTER_DIR = Path.home() / ".painter"
CARDS_DIR = PAINTER_DIR / "cards"
COUNTER_FILE = PAINTER_DIR / ".counter"
VALID_STATUSES = {"inbox", "not-now", "active", "done"}


def read_counter() -> int:
    if not COUNTER_FILE.exists():
        return 0
    return int(COUNTER_FILE.read_text().strip())


def write_counter(value: int) -> None:
    COUNTER_FILE.write_text(str(value))


def next_id() -> str:
    current = read_counter()
    next_val = current + 1
    write_counter(next_val)
    return f"{next_val:03d}"


def slugify(title: str) -> str:
    slug = title.lower()
    slug = re.sub(r"[^\w\s-]", "", slug)
    slug = re.sub(r"[\s_]+", "-", slug)
    slug = re.sub(r"-+", "-", slug)
    return slug.strip("-")


def parse_tags(tags_str: str) -> list[str]:
    if not tags_str:
        return []
    return [t.strip() for t in tags_str.split(",") if t.strip()]


def scaffold_body() -> str:
    return """
## Objective
<!-- What you're trying to accomplish and why. -->

## Context
<!-- Relevant background. Links to Jira, Sentry, docs. -->

## Current focus
<!-- What's being worked on right now. -->
""".lstrip()


def build_frontmatter(card_id: str, title: str, status: str, tags: list[str]) -> str:
    today = date.today().isoformat()
    tags_yaml = f"[{', '.join(tags)}]" if tags else "[]"
    return f"""---
id: {card_id}
title: "{title}"
status: {status}
tags: {tags_yaml}
sessions: []
created: {today}
updated: {today}
---
"""


def create_card(title: str, status: str, tags: list[str]) -> dict:
    CARDS_DIR.mkdir(parents=True, exist_ok=True)

    card_id = next_id()
    slug = slugify(title)
    filename = f"{card_id}-{slug}.md"
    card_path = CARDS_DIR / filename

    content = build_frontmatter(card_id, title, status, tags) + "\n" + scaffold_body()
    card_path.write_text(content)

    return {
        "id": card_id,
        "title": title,
        "status": status,
        "tags": tags,
        "path": str(card_path),
    }


def main():
    parser = argparse.ArgumentParser(description="Create a new painter card")
    parser.add_argument("--title", required=True, help="Card title")
    parser.add_argument(
        "--status",
        default="inbox",
        choices=sorted(VALID_STATUSES),
        help="Initial status (default: inbox)",
    )
    parser.add_argument(
        "--tags",
        default="",
        help="Comma-separated tags (e.g. feature,api,sentry)",
    )
    parser.add_argument(
        "--format",
        dest="fmt",
        default="json",
        choices=["json", "text"],
        help="Output format (default: json)",
    )
    args = parser.parse_args()

    tags = parse_tags(args.tags)
    card = create_card(args.title, args.status, tags)

    if args.fmt == "json":
        print(json.dumps(card, indent=2))
    else:
        print(f"{card['id']}  {card['status']}  {card['title']}")
        print(f"path: {card['path']}")


if __name__ == "__main__":
    main()
