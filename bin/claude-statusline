#!/usr/bin/env bash

# Statusline: model + context window + all rate/usage limits (any billing model)

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
MAGENTA='\033[0;35m'
DIM='\033[2m'
RESET='\033[0m'

SEP="${DIM}│${RESET}"

USAGE_CACHE_TTL="${CLAUDE_STATUSLINE_USAGE_TTL:-120}"
USAGE_CACHE_DIR="${TMPDIR:-/tmp}/claude-statusline-cache"

input=$(cat)

# ── Model ─────────────────────────────────────────────────────────────────────

get_model_name() { echo "$input" | jq -r '.model.display_name // "Unknown Model"' | sed 's/ (.*)//'; }

# ── Portable helpers ──────────────────────────────────────────────────────────

file_mtime() {
  stat -c "%Y" "$1" 2>/dev/null || stat -f "%m" "$1" 2>/dev/null
}

iso_to_epoch() {
  local ts="$1"
  local normalized="${ts/+00:00/Z}"
  normalized=$(echo "$normalized" | sed 's/\.[0-9]*Z/Z/')
  date -u -d "$normalized" "+%s" 2>/dev/null \
    || date -u -jf "%Y-%m-%dT%H:%M:%SZ" "$normalized" "+%s" 2>/dev/null
}

get_oauth_token() {
  if command -v security >/dev/null 2>&1; then
    security find-generic-password -s "Claude Code-credentials" -w 2>/dev/null \
      | jq -r '.claudeAiOauth.accessToken // empty'
    return
  fi
  local creds="${HOME}/.claude/.credentials.json"
  [ -f "$creds" ] && jq -r '.claudeAiOauth.accessToken // empty' "$creds" 2>/dev/null
}

format_time_until() {
  local resets_at="$1"
  [ -z "$resets_at" ] && return

  local reset_epoch
  reset_epoch=$(iso_to_epoch "$resets_at") || return
  [ -z "$reset_epoch" ] && return

  local now
  now=$(date "+%s")
  [ "$now" -ge "$reset_epoch" ] && echo "now" && return

  local secs=$((reset_epoch - now))
  local mins=$((secs / 60))
  local hours=$((mins / 60))
  local days=$((hours / 24))

  if [ "$days" -gt 0 ]; then
    printf "%dd%dh" "$days" $((hours % 24))
  elif [ "$hours" -gt 0 ]; then
    printf "%dh%dm" "$hours" $((mins % 60))
  else
    printf "%dm" "$mins"
  fi
}

# ── OAuth usage (for reset times only) ────────────────────────────────────────

read_usage_cache() {
  local cache_file="${USAGE_CACHE_DIR}/usage.json"
  [ -f "$cache_file" ] || return 1
  local file_mod
  file_mod=$(file_mtime "$cache_file") || return 1
  local now
  now=$(date "+%s")
  [ $((now - file_mod)) -lt "$USAGE_CACHE_TTL" ] || return 1
  cat "$cache_file"
}

fetch_usage() {
  local token
  token=$(get_oauth_token) || return 1
  [ -n "$token" ] || return 1
  mkdir -p "$USAGE_CACHE_DIR"
  local response
  response=$(curl -s --max-time 3 \
    -H "Authorization: Bearer $token" \
    -H "anthropic-beta: oauth-2025-04-20" \
    "https://api.anthropic.com/api/oauth/usage" 2>/dev/null) || return 1
  echo "$response" | jq -e 'type == "object"' >/dev/null 2>&1 || return 1
  echo "$response" > "${USAGE_CACHE_DIR}/usage.json"
  echo "$response"
}

read_stale_cache() {
  local cache_file="${USAGE_CACHE_DIR}/usage.json"
  [ -f "$cache_file" ] && cat "$cache_file"
}

get_oauth_usage() {
  local data
  data=$(read_usage_cache) && echo "$data" && return
  data=$(fetch_usage) && echo "$data" && return
  read_stale_cache
}

# ── Shared bar renderer ────────────────────────────────────────────────────────

# Args: $1=remaining_pct (0-100 int), $2=label, $3=time_until (optional)
build_bar() {
  local remaining="$1" label="$2" time_until="$3"
  local bar_width=5
  local filled=$((remaining * bar_width / 100))
  local empty=$((bar_width - filled))

  [ "$filled" -gt "$bar_width" ] && filled=$bar_width && empty=0
  [ "$filled" -lt 0 ] && filled=0 && empty=$bar_width

  local bar_color
  if [ "$remaining" -gt 50 ]; then bar_color="$GREEN"
  elif [ "$remaining" -gt 20 ]; then bar_color="$YELLOW"
  else bar_color="$RED"
  fi

  local bar=""
  for ((i = 0; i < filled; i++)); do bar+="━"; done
  for ((i = 0; i < empty; i++)); do bar+="╌"; done

  if [ -n "$time_until" ]; then
    printf "${DIM}%s${RESET} %s%s%s %d%% ${DIM}↻%s${RESET}" \
      "$label" "$bar_color" "$bar" "$RESET" "$remaining" "$time_until"
  else
    printf "${DIM}%s${RESET} %s%s%s %d%%" \
      "$label" "$bar_color" "$bar" "$RESET" "$remaining"
  fi
}

# ── Context window ─────────────────────────────────────────────────────────────

build_context_display() {
  local used_pct
  used_pct=$(echo "$input" | jq -r '.context_window.used_percentage // empty')
  [ -z "$used_pct" ] || [ "$used_pct" = "null" ] && return

  local used_int remaining
  used_int=$(printf "%.0f" "$used_pct")
  remaining=$((100 - used_int))

  build_bar "$remaining" "ctx"
}

# ── Rate / usage limits ────────────────────────────────────────────────────────

# Map Claude Code's snake_case limit keys to short display labels
format_limit_label() {
  case "$1" in
    five_hour)  echo "5h" ;;
    seven_day)  echo "7d" ;;
    one_hour)   echo "1h" ;;
    daily)      echo "1d" ;;
    monthly)    echo "mo" ;;
    session)    echo "ses" ;;
    *)          echo "$1" | sed 's/_[a-z]/\u&/g; s/_//g' | cut -c1-4 ;;
  esac
}

build_rate_display() {
  local stdin_limits
  stdin_limits=$(echo "$input" | jq -r '.rate_limits // empty')

  local parts=()

  if [ -n "$stdin_limits" ] && [ "$stdin_limits" != "null" ] && [ "$stdin_limits" != "{}" ]; then
    # Generic path: iterate every key Claude Code exposes (works for all billing models)
    local oauth_data
    oauth_data=$(get_oauth_usage)

    while IFS= read -r key; do
      [ -z "$key" ] && continue

      local used_pct
      used_pct=$(echo "$stdin_limits" | jq -r --arg k "$key" '.[$k].used_percentage // empty')
      [ -z "$used_pct" ] || [ "$used_pct" = "null" ] && continue

      local used_int remaining
      used_int=$(printf "%.0f" "$used_pct")
      remaining=$((100 - used_int))

      local label time_until=""
      label=$(format_limit_label "$key")

      # Supplement with reset time from OAuth cache when available
      if [ -n "$oauth_data" ]; then
        local resets_at
        resets_at=$(echo "$oauth_data" | jq -r --arg k "$key" '.[$k].resets_at // empty')
        [ -n "$resets_at" ] && time_until=$(format_time_until "$resets_at")
      fi

      parts+=("$(build_bar "$remaining" "$label" "$time_until")")
    done < <(echo "$stdin_limits" | jq -r 'keys[]')

  else
    # Fallback: OAuth-only (no stdin rate_limits — older Claude Code)
    local oauth_data
    oauth_data=$(get_oauth_usage)
    [ -z "$oauth_data" ] && return

    local five_reset seven_reset
    five_reset=$(echo "$oauth_data" | jq -r '.five_hour.resets_at // empty')
    seven_reset=$(echo "$oauth_data" | jq -r '.seven_day.resets_at // empty')
    [ -z "$five_reset" ] && [ -z "$seven_reset" ] && return

    local five_used seven_used
    five_used=$(echo "$oauth_data" | jq -r '.five_hour.utilization // 0' | xargs printf "%.0f")
    seven_used=$(echo "$oauth_data" | jq -r '.seven_day.utilization // 0' | xargs printf "%.0f")

    parts+=("$(build_bar $((100 - five_used)) "5h" "$(format_time_until "$five_reset")")")
    parts+=("$(build_bar $((100 - seven_used)) "7d" "$(format_time_until "$seven_reset")")")
  fi

  local count=${#parts[@]}
  [ "$count" -eq 0 ] && return

  local result=""
  for ((i = 0; i < count; i++)); do
    [ -n "$result" ] && result+=" ${DIM}╱${RESET} "
    result+="${parts[$i]}"
  done
  printf "%s" "$result"
}

# ── Render ────────────────────────────────────────────────────────────────────

model=$(get_model_name)
ctx_display=$(build_context_display)
rate_display=$(build_rate_display)

statusline="${MAGENTA}${model}${RESET}"
if [ -n "$ctx_display" ]; then
  statusline+=" ${SEP} ${ctx_display}"
fi
if [ -n "$rate_display" ]; then
  statusline+=" ${SEP} ${rate_display}"
fi

echo -e "$statusline"
