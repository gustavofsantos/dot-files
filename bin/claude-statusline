#!/usr/bin/env bash

# Minimalistic Claude statusline: selected model + session usage only.

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
MAGENTA='\033[0;35m'
CYAN='\033[0;36m'
DIM='\033[2m'
RESET='\033[0m'

SEP="${DIM}│${RESET}"

# Nerd font usage icon
ICON_USAGE="${YELLOW}$(printf '\U000f0241')${RESET}"

# Usage cache config
USAGE_CACHE_TTL="${CLAUDE_STATUSLINE_USAGE_TTL:-120}"
USAGE_CACHE_DIR="${TMPDIR:-/tmp}/claude-statusline-cache"

# Read JSON input from stdin
input=$(cat)

# ── Model ─────────────────────────────────────────────────────────────────────

get_model_name() { echo "$input" | jq -r '.model.display_name // "Unknown Model"' | sed 's/ (.*)//'; }

get_model_icon() {
  case "$(get_model_name)" in
  *[Oo]pus*) printf "${MAGENTA}\U000f01e5${RESET}" ;;
  *[Ss]onnet*) printf "${CYAN}\U000f075a${RESET}" ;;
  *[Hh]aiku*) printf "${GREEN}\U000f0735${RESET}" ;;
  *) printf "${DIM}\U000f06a9${RESET}" ;;
  esac
}

# ── Portable helpers (macOS / Linux) ──────────────────────────────────────────

# File modification time as epoch seconds
file_mtime() {
  stat -c "%Y" "$1" 2>/dev/null || stat -f "%m" "$1" 2>/dev/null
}

# ISO 8601 timestamp → epoch seconds
iso_to_epoch() {
  local ts="$1"
  # Normalize: +00:00 → Z, strip fractional seconds
  local normalized="${ts/+00:00/Z}"
  normalized=$(echo "$normalized" | sed 's/\.[0-9]*Z/Z/')
  date -u -d "$normalized" "+%s" 2>/dev/null \
    || date -u -jf "%Y-%m-%dT%H:%M:%SZ" "$normalized" "+%s" 2>/dev/null
}

# OAuth access token: macOS keychain → Linux credentials file
get_oauth_token() {
  if command -v security >/dev/null 2>&1; then
    security find-generic-password -s "Claude Code-credentials" -w 2>/dev/null \
      | jq -r '.claudeAiOauth.accessToken // empty'
    return
  fi
  local creds="${HOME}/.claude/.credentials.json"
  [ -f "$creds" ] && jq -r '.claudeAiOauth.accessToken // empty' "$creds" 2>/dev/null
}

# ── Usage limits ──────────────────────────────────────────────────────────────

format_time_until() {
  local resets_at="$1"
  [ -z "$resets_at" ] && echo "?" && return

  local reset_epoch
  reset_epoch=$(iso_to_epoch "$resets_at") || { echo "?"; return; }
  [ -z "$reset_epoch" ] && { echo "?"; return; }

  local now
  now=$(date "+%s")
  [ "$now" -ge "$reset_epoch" ] && { echo "now"; return; }

  local secs=$((reset_epoch - now))
  local mins=$((secs / 60))
  local hours=$((mins / 60))
  local days=$((hours / 24))

  if [ "$days" -gt 0 ]; then
    printf "%dd%dh" "$days" $((hours % 24))
  elif [ "$hours" -gt 0 ]; then
    printf "%dh%dm" "$hours" $((mins % 60))
  else
    printf "%dm" "$mins"
  fi
}

read_usage_cache() {
  local cache_file="${USAGE_CACHE_DIR}/usage.json"
  [ -f "$cache_file" ] || return 1

  local file_mod
  file_mod=$(file_mtime "$cache_file") || return 1
  local now
  now=$(date "+%s")
  [ $((now - file_mod)) -lt "$USAGE_CACHE_TTL" ] || return 1
  cat "$cache_file"
}

fetch_usage() {
  local token
  token=$(get_oauth_token) || return 1
  [ -n "$token" ] || return 1

  mkdir -p "$USAGE_CACHE_DIR"

  local response
  response=$(curl -s --max-time 3 \
    -H "Authorization: Bearer $token" \
    -H "anthropic-beta: oauth-2025-04-20" \
    "https://api.anthropic.com/api/oauth/usage" 2>/dev/null) || return 1

  echo "$response" | jq -e 'has("five_hour")' >/dev/null 2>&1 || return 1

  echo "$response" > "${USAGE_CACHE_DIR}/usage.json"
  echo "$response"
}

read_stale_cache() {
  local cache_file="${USAGE_CACHE_DIR}/usage.json"
  [ -f "$cache_file" ] && cat "$cache_file"
}

get_usage_data() {
  local data
  data=$(read_usage_cache) && echo "$data" && return
  data=$(fetch_usage) && echo "$data" && return
  read_stale_cache
}

# Mini usage bar for a single window
# Args: $1=remaining_pct (0-100), $2=label, $3=time_until
build_usage_bar() {
  local remaining="$1" label="$2" time_until="$3"
  local bar_width=5
  local filled=$((remaining * bar_width / 100))
  local empty=$((bar_width - filled))

  [ "$filled" -gt "$bar_width" ] && filled=$bar_width && empty=0
  [ "$filled" -lt 0 ] && filled=0 && empty=$bar_width

  local bar_color
  if [ "$remaining" -gt 50 ]; then
    bar_color="$GREEN"
  elif [ "$remaining" -gt 20 ]; then
    bar_color="$YELLOW"
  else
    bar_color="$RED"
  fi

  local bar=""
  for ((i = 0; i < filled; i++)); do bar+="━"; done
  for ((i = 0; i < empty; i++)); do bar+="╌"; done

  printf "${DIM}%s${RESET} %s%s%s %d%% ${DIM}↻%s${RESET}" \
    "$label" "$bar_color" "$bar" "$RESET" "$remaining" "$time_until"
}

build_usage_display() {
  local data
  data=$(get_usage_data) || return

  local five_used seven_used five_reset seven_reset
  five_used=$(echo "$data" | jq -r '.five_hour.utilization // 0' | xargs printf "%.0f")
  seven_used=$(echo "$data" | jq -r '.seven_day.utilization // 0' | xargs printf "%.0f")
  five_reset=$(echo "$data" | jq -r '.five_hour.resets_at // empty')
  seven_reset=$(echo "$data" | jq -r '.seven_day.resets_at // empty')

  # No active rate windows (e.g., enterprise billing) — nothing to show
  [ -z "$five_reset" ] && [ -z "$seven_reset" ] && return

  local five_bar seven_bar
  five_bar=$(build_usage_bar $((100 - five_used)) "5h" "$(format_time_until "$five_reset")")
  seven_bar=$(build_usage_bar $((100 - seven_used)) "7d" "$(format_time_until "$seven_reset")")

  printf "%s ${DIM}╱${RESET} %s" "$five_bar" "$seven_bar"
}

# ── Render ────────────────────────────────────────────────────────────────────

model=$(get_model_name)
model_icon=$(get_model_icon)
usage_display=$(build_usage_display)

statusline="${model_icon} ${MAGENTA}${model}${RESET}"
if [ -n "$usage_display" ]; then
  statusline+=" ${SEP} ${ICON_USAGE} ${usage_display}"
fi

echo -e "$statusline"
