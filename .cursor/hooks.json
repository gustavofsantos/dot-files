{
  "version": 1,
  "hooks": {
    "sessionStart": [
      { "command": "hooks-runner cursor sessionStart" }
    ],
    "beforeSubmitPrompt": [
      { "command": "hooks-runner cursor beforeSubmitPrompt" }
    ],
    "stop": [
      { "command": "hooks-runner cursor stop" }
    ],
    "sessionEnd": [
      { "command": "hooks-runner cursor sessionEnd" }
    ]
  }
}
